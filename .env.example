# pgAdmin credentials (set strong, unique values in your real .env or secret manager)
PGADMIN_DEFAULT_EMAIL=admin+pgadmin-change-me@example.com
PGADMIN_DEFAULT_PASSWORD=CHANGEME_generate_32plus_char_unique_secret
# Domain for TLS routing
DOMAIN_NAME=example.com
SUBDOMAIN=n8n
SSL_EMAIL=you@example.com

# Database
POSTGRES_PASSWORD=replace-with-a-strong-password

# n8n
GENERIC_TIMEZONE=UTC

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=replace-with-a-strong-password
