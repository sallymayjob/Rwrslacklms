# Copy this file to .env before local docker compose usage.
# Hostinger Docker Manager can define these directly in its Environment Variables UI.

# Postgres credentials
POSTGRES_USER=n8n
POSTGRES_PASSWORD=replace-with-a-strong-password
POSTGRES_DB=n8n

# n8n security/settings
N8N_HOST=0.0.0.0
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_EDITOR_BASE_URL=http://YOUR_PUBLIC_HOST_OR_IP:5678
WEBHOOK_URL=http://YOUR_PUBLIC_HOST_OR_IP:5678
N8N_ENCRYPTION_KEY=replace-with-a-long-random-string
GENERIC_TIMEZONE=UTC
